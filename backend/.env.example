SECRET_KEY=replace-with-a-long-random-string
DATABASE_URL=postgresql+asyncpg://netdash:netdash@postgres:5432/netdash
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEFAULT_POLL_INTERVAL_SECONDS=30

# Encrypts SNMP community strings (and any future device credentials) at
# rest in the database. This is a real, working default so local dev works
# out of the box — generate your own before deploying anywhere real:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=OloammpEtjFOpKutsR5HM3liEnNhu9Ean8X-qhRfedI=

# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend's real origin here before going anywhere near production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Alerting (all optional — leave blank to disable). See app/services/notifier.py
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_ADDRESS=you@example.com
# ALERT_EMAIL_TO=you@example.com,teammate@example.com
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Minimum seconds between alerts for the same device, to prevent a flapping
# device from spamming your inbox/webhook on every single transition.
ALERT_COOLDOWN_SECONDS=300
